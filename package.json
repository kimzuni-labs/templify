{
  "name": "@kimzuni/templify-monorepo",
  "private": true,
  "type": "module",
  "workspaces": ["packages/**"],
  "scripts": {
    "test": "npm --workspaces --if-present run test",
    "test:all": "npm --workspaces --if-present run test:all",
    "lint": "markdownlint-cli2 && yamllint . && eslint .",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "lint:yaml": "yamllint .",
    "build": "npm --workspaces --if-present run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@eslint/js": "9.39.2",
    "@stylistic/eslint-plugin": "5.6.1",
    "@types/bun": "1.3.5",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "markdownlint-cli2": "0.20.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "yamllint-js": "0.1.0"
  }
}
