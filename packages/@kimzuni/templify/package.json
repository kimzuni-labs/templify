{
  "name": "@kimzuni/templify",
  "description": "Flexible template string processor for JavaScript and TypeScript.",
  "version": "1.3.0",
  "license": "MIT",
  "private": false,
  "type": "module",
  "author": {
    "name": "kimzuni",
    "email": "me@zuni.kim",
    "url": "https://github.com/kimzuni"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimzuni-labs/templify.git",
    "directory": "packages/@kimzuni/templify"
  },
  "homepage": "https://github.com/kimzuni-labs/templify/tree/main/packages/@kimzuni/templify",
  "bugs": "https://github.com/kimzuni-labs/templify/issues",
  "scripts": {
    "test": "NODE_ENV=test tsx --test",
    "test:all": "NODE_ENV=test tsx --test tests/*.test.ts",
    "lint": "markdownlint-cli2 && yamllint . && eslint .",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "lint:yaml": "yamllint .",
    "build": "tsdown"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "template",
    "string",
    "render",
    "placeholder",
    "typescript"
  ],
  "devDependencies": {
    "tsdown": "0.18.3"
  }
}
